trauma %>%
summary()
library(summarytools)
view(dfSummary(trauma,
plain.ascii = FALSE,
style = "grid"))
trauma <- trauma %>%
mutate(id = as.factor(id),
Sex = as.factor(Sex),
Height = as.numeric(sub("\"", "", Height)),
Death  = as.factor(Death))
trauma %>%
summary()
view(dfSummary(trauma,
plain.ascii = FALSE,
style = "grid"))
n_male <- trauma %>%
filter(Sex == 'Male') %>%
nrow()
Hb_low_male <- trauma %>%
filter(Sex == 'Male') %>%
filter(Hb <= 13.5) %>%
nrow()
n_female <- trauma %>%
filter(Sex == 'Female') %>%
nrow()
Hb_low_female <- trauma %>%
filter(Sex == 'Female') %>%
filter(Hb <= 12) %>%
nrow()
data.frame(n_male = n_male,
p_male = round(Hb_low_male/n_male, 2),
n_female = n_female,
p_female = round(Hb_low_female/n_female, 2))
