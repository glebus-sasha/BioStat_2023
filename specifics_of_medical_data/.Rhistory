library (pROC)
#define object to plot
rocobj <- roc(trauma$Death, predicted)
auc <- round (auc(trauma$Death, predicted), 4 )
#create ROC plot
ggroc(rocobj) +
ggtitle( paste0('ROC Curve', '(AUC =', auc, ')'))
