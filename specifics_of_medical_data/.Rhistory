library(dplyr)
library(ggplot2)
library(readxl)
library(tidyverse)
library(rstatix)
library(pROC)
library(gtsummary)
trauma <- read_excel('trauma.xlsx', range = cell_cols("B:M"))
trauma %>%
summary()
library(summarytools)
view(dfSummary(trauma,
plain.ascii = FALSE,
style = "grid"))
trauma <- trauma %>%
mutate(id = as.factor(id),
Sex = as.factor(Sex),
Height = as.numeric(sub("\"", "", Height)),
Death  = as.factor(Death))
trauma %>%
summary()
View(trauma)
trauma <- read_excel('trauma.xlsx', range = cell_cols("B:M"))
